<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1"/>
<title>TGSPDCL — SCADA Command Centre | James Street Sub-Division</title>
<link href="https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Orbitron:wght@400;600;800&family=Rajdhani:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#040d18;
  --panel:rgba(8,22,42,0.92);
  --live:#00e5ff;
  --ok:#00e676;
  --fault:#ff1744;
  --idle:#78909c;
  --trip:#ffab00;
  --border:rgba(0,229,255,0.15);
  --mono:'Share Tech Mono',monospace;
  --head:'Orbitron',sans-serif;
  --body:'Rajdhani',sans-serif;
}
html,body{width:100%;min-height:100vh;background:var(--bg);color:#c8dff0;font-family:var(--body);overflow-x:hidden}

/* ── BACKGROUND GRID ── */
body::before{
  content:'';position:fixed;inset:0;z-index:0;
  background-image:
    linear-gradient(rgba(0,229,255,0.03) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,229,255,0.03) 1px,transparent 1px);
  background-size:40px 40px;
  pointer-events:none;
}
body::after{
  content:'';position:fixed;inset:0;z-index:0;
  background:radial-gradient(ellipse 80% 50% at 50% 0%,rgba(0,100,180,0.18) 0%,transparent 70%);
  pointer-events:none;
}

/* ── HEADER ── */
#header{
  position:sticky;top:0;z-index:100;
  background:rgba(4,13,24,0.97);
  border-bottom:1px solid var(--border);
  backdrop-filter:blur(20px);
  padding:0 28px;
  height:60px;
  display:flex;align-items:center;gap:20px;
}
.hd-logo{
  font-family:var(--head);font-size:14px;font-weight:800;
  color:var(--live);letter-spacing:3px;white-space:nowrap;
}
.hd-sep{width:1px;height:32px;background:var(--border)}
.hd-title{font-family:var(--body);font-weight:600;font-size:13px;color:#7aadcc;letter-spacing:1px;flex:1}
.hd-clock{font-family:var(--mono);font-size:12px;color:var(--live);letter-spacing:1px}
.hd-btn{
  font-family:var(--mono);font-size:10px;letter-spacing:1.5px;
  padding:6px 16px;border-radius:4px;cursor:pointer;
  border:1px solid;transition:all 0.2s;text-decoration:none;
  display:flex;align-items:center;gap:6px;white-space:nowrap;
}
.hd-btn-entry{color:var(--trip);border-color:rgba(255,171,0,0.4);background:rgba(255,171,0,0.07)}
.hd-btn-entry:hover{background:rgba(255,171,0,0.18);box-shadow:0 0 12px rgba(255,171,0,0.2)}

/* ── SUMMARY BAR ── */
#summary{
  position:relative;z-index:1;
  display:flex;gap:12px;padding:20px 28px 0;
  flex-wrap:wrap;
}
.sum-card{
  flex:1;min-width:140px;
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:8px;padding:14px 18px;
  display:flex;flex-direction:column;gap:4px;
  position:relative;overflow:hidden;
}
.sum-card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
}
.sum-card.s-live::before{background:var(--ok)}
.sum-card.s-fault::before{background:var(--fault)}
.sum-card.s-idle::before{background:var(--idle)}
.sum-card.s-total::before{background:var(--live)}
.sum-label{font-family:var(--mono);font-size:8px;letter-spacing:2px;color:rgba(200,223,240,0.4)}
.sum-val{font-family:var(--head);font-size:26px;font-weight:800;line-height:1}
.sum-card.s-live .sum-val{color:var(--ok)}
.sum-card.s-fault .sum-val{color:var(--fault)}
.sum-card.s-idle .sum-val{color:var(--idle)}
.sum-card.s-total .sum-val{color:var(--live)}
.sum-sub{font-size:10px;color:rgba(200,223,240,0.35);font-family:var(--mono)}

/* ── SECTION LABEL ── */
.sec-label{
  position:relative;z-index:1;
  padding:22px 28px 10px;
  font-family:var(--mono);font-size:9px;letter-spacing:3px;
  color:rgba(0,229,255,0.45);
  display:flex;align-items:center;gap:12px;
}
.sec-label::after{content:'';flex:1;height:1px;background:var(--border)}

/* ── SECTIONS GRID ── */
#sections-grid{
  position:relative;z-index:1;
  display:grid;
  grid-template-columns:repeat(auto-fill,minmax(300px,1fr));
  gap:14px;
  padding:0 28px 28px;
}

/* ── SECTION CARD ── */
.sec-card{
  background:var(--panel);
  border:1px solid var(--border);
  border-radius:10px;
  overflow:hidden;
  cursor:pointer;
  transition:all 0.25s cubic-bezier(0.4,0,0.2,1);
  text-decoration:none;color:inherit;
  display:block;position:relative;
}
.sec-card:hover{
  border-color:rgba(0,229,255,0.5);
  box-shadow:0 0 28px rgba(0,229,255,0.12),0 8px 32px rgba(0,0,0,0.4);
  transform:translateY(-3px);
}
.sec-card-top{
  padding:14px 16px 12px;
  display:flex;align-items:flex-start;gap:12px;
  border-bottom:1px solid rgba(0,229,255,0.07);
}
.sec-num{
  font-family:var(--head);font-size:11px;font-weight:800;
  color:rgba(0,229,255,0.3);letter-spacing:1px;
  background:rgba(0,229,255,0.06);
  border:1px solid rgba(0,229,255,0.12);
  border-radius:4px;padding:3px 8px;white-space:nowrap;flex-shrink:0;
  margin-top:2px;
}
.sec-info{flex:1;min-width:0}
.sec-name{
  font-family:var(--body);font-size:14px;font-weight:700;
  color:#d8ecff;line-height:1.2;margin-bottom:3px;
}
.sec-meta{font-family:var(--mono);font-size:9px;color:rgba(200,223,240,0.35);letter-spacing:.5px}
.sec-open-icon{
  font-size:16px;color:rgba(0,229,255,0.25);flex-shrink:0;
  transition:color 0.2s,transform 0.2s;margin-top:2px;
}
.sec-card:hover .sec-open-icon{color:var(--live);transform:translateX(3px)}

/* ── SUBSTATION LIST inside card ── */
.sec-ss-list{padding:10px 16px 14px;display:flex;flex-direction:column;gap:5px}
.ss-row{
  display:flex;align-items:center;gap:8px;
  padding:5px 8px;border-radius:5px;
  background:rgba(255,255,255,0.02);
  border:1px solid rgba(255,255,255,0.04);
  transition:background 0.15s;
}
.ss-row:hover{background:rgba(0,229,255,0.05)}
.ss-dot{
  width:8px;height:8px;border-radius:50%;flex-shrink:0;
  box-shadow:0 0 6px currentColor;
}
.ss-dot.live{color:var(--ok);background:var(--ok)}
.ss-dot.fault{color:var(--fault);background:var(--fault);animation:ss-blink 0.7s infinite}
.ss-dot.idle{color:var(--idle);background:var(--idle)}
@keyframes ss-blink{50%{opacity:0.2}}
.ss-name{font-family:var(--body);font-size:11px;color:#8fb8d8;flex:1;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ss-feeder{font-family:var(--mono);font-size:8px;color:rgba(200,223,240,0.3);white-space:nowrap}
.ss-status-badge{
  font-family:var(--mono);font-size:7px;letter-spacing:1px;
  padding:1px 6px;border-radius:10px;font-weight:700;white-space:nowrap;
}
.ss-status-badge.live{color:var(--ok);background:rgba(0,230,118,0.12);border:1px solid rgba(0,230,118,0.25)}
.ss-status-badge.fault{color:var(--fault);background:rgba(255,23,68,0.12);border:1px solid rgba(255,23,68,0.25);animation:ss-blink 0.7s infinite}
.ss-status-badge.idle{color:var(--idle);background:rgba(120,144,156,0.12);border:1px solid rgba(120,144,156,0.25)}

/* ── SHOW MORE button ── */
.ss-more{
  font-family:var(--mono);font-size:9px;color:rgba(0,229,255,0.4);
  letter-spacing:1px;padding:4px 8px;cursor:pointer;
  text-align:center;border-top:1px solid rgba(0,229,255,0.06);
  transition:color 0.2s;
}
.ss-more:hover{color:var(--live)}

/* ── STATUS STRIP at top of card ── */
.sec-card-strip{height:3px;width:100%}
.strip-live{background:linear-gradient(90deg,var(--ok),transparent)}
.strip-fault{background:linear-gradient(90deg,var(--fault),transparent);animation:ss-blink 0.7s infinite}
.strip-mixed{background:linear-gradient(90deg,var(--trip),transparent)}

/* ── TOAST ── */
#toast{
  position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(20px);
  z-index:500;background:rgba(4,13,24,0.97);border:1px solid var(--border);
  border-radius:8px;padding:10px 20px;font-family:var(--mono);font-size:11px;
  color:var(--live);opacity:0;pointer-events:none;transition:all 0.3s;
  white-space:nowrap;
}
#toast.show{opacity:1;transform:translateX(-50%) translateY(0)}

/* ── SCAN ANIMATION on load ── */
@keyframes scanline{
  0%{top:-5%}100%{top:105%}
}
.scanline{
  position:fixed;left:0;right:0;height:2px;z-index:200;
  background:linear-gradient(90deg,transparent,rgba(0,229,255,0.4),transparent);
  animation:scanline 2s linear 1;
  pointer-events:none;
}
</style>
</head>
