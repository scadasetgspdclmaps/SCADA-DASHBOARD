// ══════════════════════════════════════════════════
// STATUS STORE (localStorage — persists across page visits)
// Keys: feeder_status_{feederName} → 'live'|'breakdown'|'idle'
//       ss_status_{ssCode}         → 'live'|'breakdown'|'idle'
// ══════════════════════════════════════════════════
function getStatus(key){ return localStorage.getItem(key) || 'live'; }
function setStatus(key, val){ localStorage.setItem(key, val); }

// ── Compute summary counts ──
function updateSummary(){
  const allFeeders = new Set();
  SECTIONS.forEach(s => s.feeders.forEach(f => allFeeders.add(f)));
  let live=0, fault=0, idle=0;
  allFeeders.forEach(f => {
    const s = getStatus('feeder_status_'+f);
    if(s==='breakdown') fault++;
    else if(s==='idle') idle++;
    else live++;
  });
  document.getElementById('sum-live').textContent  = live;
  document.getElementById('sum-fault').textContent = fault;
  document.getElementById('sum-idle').textContent  = idle;
}

// ── Build section cards ──
function buildCards(){
  const grid = document.getElementById('sections-grid');
  grid.innerHTML = '';

  SECTIONS.forEach((sec, idx) => {
    // Determine section overall status from its feeders
    const statuses = sec.feeders.map(f => getStatus('feeder_status_'+f));
    const hasFault = statuses.includes('breakdown');
    const allIdle  = statuses.every(s => s==='idle');
    const secStatus = hasFault ? 'fault' : allIdle ? 'idle' : 'live';

    const card = document.createElement('a');
    card.href = sec.mapUrl;
    card.className = 'sec-card';
    card.style.animationDelay = (idx * 0.04) + 's';

    // Strip colour
    const stripClass = hasFault ? 'strip-fault' : allIdle ? '' : 'strip-live';

    // SS rows (show max 4, collapse rest)
    const maxShow = 4;
    const ssRows = sec.substations.map((ss, si) => {
      const st = getStatus('ss_status_'+ss.code);
      const feeder = sec.feeders[0] || '';
      const feederShort = feeder.split('→')[1]?.trim().substring(0,12) || feeder.substring(0,12);
      return `<div class="ss-row${si >= maxShow ? ' ss-hidden' : ''}" style="${si >= maxShow ? 'display:none' : ''}">
        <div class="ss-dot ${st}"></div>
        <span class="ss-name">${ss.name.replace('33/11 KV ','').replace('33/11KV ','')}</span>
        <span class="ss-feeder">${feederShort}</span>
        <span class="ss-status-badge ${st}">${st.toUpperCase()}</span>
      </div>`;
    }).join('');

    const moreBtn = sec.substations.length > maxShow
      ? `<div class="ss-more" onclick="toggleMore(this,event)">▾ ${sec.substations.length - maxShow} more</div>`
      : '';

    card.innerHTML = `
      <div class="sec-card-strip ${stripClass}"></div>
      <div class="sec-card-top">
        <div class="sec-num">${sec.num}</div>
        <div class="sec-info">
          <div class="sec-name">${sec.name}</div>
          <div class="sec-meta">${sec.division} DIV · ${sec.subdivision} SECTION · ${sec.feeders.length} FEEDER${sec.feeders.length>1?'S':''} · ${sec.substations.length} SS</div>
        </div>
        <div class="sec-open-icon">→</div>
      </div>
      <div class="sec-ss-list">${ssRows}</div>
      ${moreBtn}
    `;

    grid.appendChild(card);
  });

  updateSummary();
}

function toggleMore(btn, e){
  e.preventDefault();
  e.stopPropagation();
  const list = btn.previousElementSibling;
  const hidden = list.querySelectorAll('.ss-hidden');
  const showing = btn.dataset.expanded === '1';
  hidden.forEach(el => el.style.display = showing ? 'none' : 'flex');
  btn.dataset.expanded = showing ? '' : '1';
  btn.textContent = showing
    ? `▾ ${hidden.length} more`
    : `▴ show less`;
}

// ── Clock ──
function updateClock(){
  const now = new Date();
  document.getElementById('clock').textContent =
    now.toLocaleTimeString('en-IN',{hour12:false}) + ' IST';
}
updateClock();
setInterval(updateClock, 1000);

// ── Toast ──
let _tt;
function toast(msg){
  const t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  clearTimeout(_tt); _tt = setTimeout(()=>t.classList.remove('show'), 2500);
}

// ── Remove scanline after animation ──
setTimeout(()=>{
  const s = document.getElementById('scanline');
  if(s) s.remove();
}, 2100);

// ── Init ──
buildCards();

// Auto-refresh summary every 30s
setInterval(()=>{ buildCards(); }, 30000);
</script>
</body>
