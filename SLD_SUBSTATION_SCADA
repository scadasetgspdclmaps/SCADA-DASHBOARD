/* ---------- EXPORT SVG (theme + boost) ---------- */
function exportSvg(boost,themeKey){
  boost=boost||1;
  const clone=vp.cloneNode(true);clone.removeAttribute("transform");
  clone.querySelectorAll('.selBox,.flowDots,#underlayImg').forEach(n=>n.remove());
  let html=clone.innerHTML.replace(/font-size:\s*([\d.]+)px/g,(m,v)=>"font-size:"+(parseFloat(v)*boost).toFixed(1)+"px");
  const themes={"":{paper:"#0e1318",sym:"#dfe9f2",symfill:"#11171e",wire:"#506f8f",energ:"#00e676"},
    "th-light":{paper:"#ffffff",sym:"#000000",symfill:"#ffffff",wire:"#0a0a0a",energ:"#0a7a2f"},
    "th-blue":{paper:"#05202f",sym:"#a4d8f8",symfill:"#05202f",wire:"#4f7f9f",energ:"#00e676"}};
  const T=themes[themeKey!==undefined?themeKey:(svg.classList.contains("th-light")?"th-light":svg.classList.contains("th-blue")?"th-blue":"")];
  const bl=(11*boost).toFixed(1),bb=(12*boost).toFixed(1);
  return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1600 980" width="1600" height="980" style="--paper:${T.paper};--sym:${T.sym};--symfill:${T.symfill};--wire:${T.wire};--energ:${T.energ}">
 <style>text.lbl{font-family:'Courier New',monospace;font-size:${bl}px;fill:var(--sym)}text.lblB{font-family:'Courier New',monospace;font-weight:bold;font-size:${bb}px;fill:var(--sym)}.wire{stroke:var(--wire);stroke-width:2.2;fill:none}.wire.busline{stroke-width:6}.wire.flowing{stroke:var(--energ)}#paper{fill:var(--paper);stroke:var(--sym)}</style>${html}</svg>`;
}
