/* ---------- POINTER ---------- */
let drag=null,pan=null,pinch=null,moved=false;const touches=new Map();
svg.addEventListener('pointerdown',ev=>{
  touches.set(ev.pointerId,[ev.clientX,ev.clientY]);
  if(touches.size===2){const pts=[...touches.values()];
    pinch={d:Math.hypot(pts[0][0]-pts[1][0],pts[0][1]-pts[1][1]),k:view.k,cx:(pts[0][0]+pts[1][0])/2,cy:(pts[0][1]+pts[1][1])/2,vx:view.x,vy:view.y};
    drag=null;pan=null;return;}
  const [wx,wy]=toWorld(ev);moved=false;const t=ev.target;
  if(!locked&&mode==="wire"){draft.push([snap(wx),snap(wy)]);drawDraft();return;}
  if(!locked&&mode==="text"){const c={id:nid("c"),type:"label",x:snap(wx),y:snap(wy),rot:0,sc:1,label:"NEW TEXT",textSize:14,bio:{}};
    state.comps.push(c);setMode("select");netDirty=true;select(c.id);pushHist();return;}
  if(!locked&&mode==="place"&&placeType){const c={id:nid("c"),type:placeType,x:snap(wx),y:snap(wy),rot:0,sc:1,label:"",len:placeType==="bus"?300:undefined,textSize:10.5,bio:{}};
    state.comps.push(c);setMode("select");netDirty=true;select(c.id);pushHist();return;}
  const compG=t.closest('.comp');
  if(compG){const c=findComp(compG.dataset.id);select(c.id);
    if(!locked){drag={id:c.id,dx:wx-c.x,dy:wy-c.y};svg.setPointerCapture(ev.pointerId);}return;}
  if(t.classList.contains('wire')){selId=t.dataset.id;closeProps();render();return;}
  select(null);pan={sx:ev.clientX,sy:ev.clientY,vx:view.x,vy:view.y};svg.setPointerCapture(ev.pointerId);
});
svg.addEventListener('pointermove',ev=>{
  if(touches.has(ev.pointerId))touches.set(ev.pointerId,[ev.clientX,ev.clientY]);
  if(pinch&&touches.size===2){const pts=[...touches.values()];
    const f=Math.hypot(pts[0][0]-pts[1][0],pts[0][1]-pts[1][1])/pinch.d;
    view.k=pinch.k*f;view.x=pinch.cx-(pinch.cx-pinch.vx)*f;view.y=pinch.cy-(pinch.cy-pinch.vy)*f;applyView();return;}
  const [wx,wy]=toWorld(ev);P('stCoord').textContent=`x:${Math.round(wx)} y:${Math.round(wy)}`;
  if(drag){moved=true;const c=findComp(drag.id);c.x=snap(wx-drag.dx);c.y=snap(wy-drag.dy);
    if(c.id===selId){P('pX').value=c.x;P('pY').value=c.y;}netDirty=true;render();return;}
  if(pan){view.x=pan.vx+(ev.clientX-pan.sx);view.y=pan.vy+(ev.clientY-pan.sy);applyView();return;}
  if(!locked&&mode==="wire"&&draft.length)drawDraft([snap(wx),snap(wy)]);
});
function endPtr(ev){touches.delete(ev.pointerId);if(touches.size<2)pinch=null;if(drag&&moved)pushHist();drag=null;pan=null;}
svg.addEventListener('pointerup',endPtr);svg.addEventListener('pointercancel',endPtr);
svg.addEventListener('dblclick',ev=>{
  const compG=ev.target.closest('.comp');
  if(compG){const c=findComp(compG.dataset.id);
    if(c&&SWITCHABLE.has(c.type)){c.open=!c.open;netDirty=true;render();
      if(c.id===selId)updSwBtn(c);toast((c.label||c.type.toUpperCase())+(c.open?" OPENED":" CLOSED"));pushHist();return;}}
  if(!locked&&mode==="wire"&&draft.length>=2){state.wires.push({id:nid("w"),pts:draft.slice()});draft=[];drawDraft();netDirty=true;render();pushHist();}
});
function drawDraft(cur){draftG.innerHTML="";if(!draft.length)return;
  const pts=cur?[...draft,cur]:draft;const p=document.createElementNS(SVGNS,'path');
  p.setAttribute("d","M"+pts.map(q=>q.join(",")).join(" L"));
  p.setAttribute("style","stroke:#ffb300;stroke-width:2;fill:none;stroke-dasharray:5 4");draftG.appendChild(p);}
window.addEventListener('keydown',ev=>{
  if(ev.target.tagName==="INPUT"||ev.target.tagName==="TEXTAREA")return;
  if(ev.key==="Delete"||ev.key==="Backspace")delSelected();
  if(ev.key==="Escape"){draft=[];drawDraft();setMode("select");}
  if(ev.ctrlKey&&ev.key==="z"){ev.preventDefault();undo();}
  if(ev.ctrlKey&&(ev.key==="y"||(ev.shiftKey&&ev.key==="Z"))){ev.preventDefault();redo();}});
svg.addEventListener('wheel',ev=>{ev.preventDefault();
  const f=ev.deltaY<0?1.12:0.89,r=svg.getBoundingClientRect(),mx=ev.clientX-r.left,my=ev.clientY-r.top;
  view.x=mx-(mx-view.x)*f;view.y=my-(my-view.y)*f;view.k*=f;applyView();},{passive:false});

