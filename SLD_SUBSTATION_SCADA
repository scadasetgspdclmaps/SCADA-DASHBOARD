<script>
"use strict";
/* ============================================================
   SLD STUDIO PRO V4
   V3 electrical engine (correct connectivity + switching)
   + Gemini UI polish + 5 fixes (breaker/fuse gating, ⊘ marks,
     paper-size print w/ boost, real underlay tracing, themes)
   ============================================================ */
const SVGNS="http://www.w3.org/2000/svg";
const svg=document.getElementById('svgHost'),vp=document.getElementById('viewport'),
 wiresG=document.getElementById('wiresG'),compsG=document.getElementById('compsG'),
 draftG=document.getElementById('wireDraftG'),uImg=document.getElementById('underlayImg');
const P=id=>document.getElementById(id);

let state={name:"33/11KV Golconda SS",comps:[],wires:[],underlay:null};
let view={x:0,y:0,k:.7};
let locked=true,mode="select",placeType=null,selId=null,draft=[],animOn=false;
let uid=1;const nid=p=>p+(uid++);
const SWITCHABLE=new Set(["breaker","isolator","abswitch","fuse"]);

/* ---------- HISTORY ---------- */
let hist=[],hPtr=-1;
function pushHist(){
  hist=hist.slice(0,hPtr+1);
  hist.push(JSON.stringify({comps:state.comps,wires:state.wires,name:state.name}));
  if(hist.length>60)hist.shift();
  hPtr=hist.length-1;updHistBtns();netDirty=true;
}
function restore(i){const s=JSON.parse(hist[i]);
  state.comps=s.comps;state.wires=s.wires;state.name=s.name;
  P('ssName').value=state.name;selId=null;closeProps();netDirty=true;render();updHistBtns();}
function undo(){if(hPtr>0){hPtr--;restore(hPtr);}}
function redo(){if(hPtr<hist.length-1){hPtr++;restore(hPtr);}}
function updHistBtns(){P('bUndo').disabled=hPtr<=0;P('bRedo').disabled=hPtr>=hist.length-1;}
P('bUndo').onclick=undo;P('bRedo').onclick=redo;

/* ---------- SYMBOLS ---------- */
const S='stroke="var(--sym)"',SF='fill="var(--symfill)"',FB='fill="var(--sym)"';
const SYM={
breaker:c=>c.open?
 `<rect x="-11" y="-11" width="22" height="22" ${SF} stroke="#ff5252" stroke-width="2"/>
  <line x1="0" y1="-16" x2="0" y2="-11" ${S} stroke-width="2"/><line x1="0" y1="11" x2="0" y2="16" ${S} stroke-width="2"/>`
 :`<rect x="-11" y="-11" width="22" height="22" ${SF} ${S} stroke-width="2"/>
  <line x1="-8" y1="-8" x2="8" y2="8" ${S} stroke-width="1.5"/><line x1="8" y1="-8" x2="-8" y2="8" ${S} stroke-width="1.5"/>
  <line x1="0" y1="-16" x2="0" y2="-11" ${S} stroke-width="2"/><line x1="0" y1="11" x2="0" y2="16" ${S} stroke-width="2"/>`,
isolator:c=>`<line x1="0" y1="-16" x2="0" y2="-5.5" ${S} stroke-width="2"/>
 <circle cx="0" cy="-5" r="3.2" ${SF} ${S} stroke-width="1.6"/>
 <line x1="0" y1="-5" x2="${c.open?14:11}" y2="${c.open?-1:5}" ${S} stroke-width="2"/>
 <circle cx="0" cy="5" r="3.2" ${SF} ${S} stroke-width="1.6"/>
 <line x1="0" y1="5.5" x2="0" y2="16" ${S} stroke-width="2"/>`,
abswitch:c=>`<line x1="0" y1="-16" x2="0" y2="-6" ${S} stroke-width="2"/>
 <line x1="0" y1="-6" x2="${c.open?15:12}" y2="${c.open?-2:6}" ${S} stroke-width="2.2"/>
 <line x1="${c.open?10:8}" y1="${c.open?-5:0}" x2="${c.open?16:14}" y2="${c.open?0:5}" ${S} stroke-width="1.4"/>
 <circle cx="0" cy="6" r="2.8" ${FB}/><line x1="0" y1="6" x2="0" y2="16" ${S} stroke-width="2"/>`,
fuse:c=>`<line x1="0" y1="-16" x2="0" y2="-12" ${S} stroke-width="2"/>
 <rect x="-7" y="-12" width="14" height="24" ${SF} stroke="${c.open?'#ff5252':'var(--sym)'}" stroke-width="1.8"/>
 <text x="0" y="4" text-anchor="middle" style="font:bold 9px 'Courier New';fill:${c.open?'#ff5252':'var(--sym)'}">F</text>
 <line x1="0" y1="12" x2="0" y2="16" ${S} stroke-width="2"/>`,
ptr:()=>`<circle cx="0" cy="-11" r="15" fill="rgba(255,80,80,.13)" stroke="#e53935" stroke-width="2"/>
 <circle cx="0" cy="11" r="15" fill="rgba(255,80,80,.13)" stroke="#e53935" stroke-width="2"/>`,
dtr:()=>`<circle cx="0" cy="-8" r="8" ${SF} ${S} stroke-width="1.7"/><circle cx="0" cy="6" r="8" ${SF} ${S} stroke-width="1.7"/>
 <line x1="0" y1="14" x2="0" y2="19" ${S} stroke-width="1.7"/><line x1="-7" y1="19" x2="7" y2="19" ${S} stroke-width="2.2"/><line x1="-4" y1="23" x2="4" y2="23" ${S} stroke-width="1.5"/>`,
la:()=>`<line x1="0" y1="0" x2="0" y2="8" ${S} stroke-width="1.8"/><polygon points="0,8 -8,22 8,22" ${FB}/>
 <line x1="0" y1="22" x2="0" y2="29" ${S} stroke-width="1.8"/><line x1="-9" y1="29" x2="9" y2="29" ${S} stroke-width="2.2"/><line x1="-6" y1="33" x2="6" y2="33" ${S} stroke-width="1.6"/><line x1="-2.5" y1="37" x2="2.5" y2="37" ${S} stroke-width="1.2"/>`,
buspt:()=>`<line x1="0" y1="0" x2="0" y2="6" ${S} stroke-width="1.8"/>
 <circle cx="0" cy="14" r="7.5" fill="rgba(80,180,255,.18)" ${S} stroke-width="1.6"/><circle cx="0" cy="28" r="7.5" fill="rgba(80,180,255,.18)" ${S} stroke-width="1.6"/>
 <line x1="0" y1="35" x2="0" y2="41" ${S} stroke-width="1.6"/><line x1="-8" y1="41" x2="8" y2="41" ${S} stroke-width="2"/><line x1="-5" y1="45" x2="5" y2="45" ${S} stroke-width="1.4"/>`,
ct:()=>`<line x1="0" y1="-16" x2="0" y2="16" ${S} stroke-width="2"/><circle cx="0" cy="0" r="9" fill="none" ${S} stroke-width="1.8"/>`,
capbank:()=>`<line x1="0" y1="0" x2="0" y2="10" ${S} stroke-width="1.8"/><rect x="-13" y="10" width="26" height="5" ${FB}/><rect x="-13" y="19" width="26" height="5" ${FB}/>
 <line x1="0" y1="24" x2="0" y2="32" ${S} stroke-width="1.8"/><line x1="-9" y1="32" x2="9" y2="32" ${S} stroke-width="2.2"/><line x1="-6" y1="36" x2="6" y2="36" ${S} stroke-width="1.6"/>`,
earth:()=>`<line x1="0" y1="0" x2="0" y2="10" ${S} stroke-width="1.8"/><line x1="-10" y1="10" x2="10" y2="10" ${S} stroke-width="2.4"/><line x1="-6.5" y1="15" x2="6.5" y2="15" ${S} stroke-width="1.8"/><line x1="-3" y1="20" x2="3" y2="20" ${S} stroke-width="1.3"/>`,
incomer:()=>`<line x1="-30" y1="0" x2="-4" y2="0" ${S} stroke-width="2.2"/><polygon points="16,0 -6,-9 -6,9" fill="#1e88e5" stroke="#0d47a1" stroke-width="1"/>`,
feederarrow:()=>`<line x1="30" y1="0" x2="4" y2="0" ${S} stroke-width="2.2"/><polygon points="-16,0 6,-9 6,9" ${FB}/>`,
};
const BOX={breaker:[30,32],isolator:[30,38],abswitch:[32,38],fuse:[22,38],
 ptr:[38,56],dtr:[24,52],la:[24,42],buspt:[24,50],ct:[24,38],
 capbank:[30,42],earth:[24,26],incomer:[52,22],feederarrow:[52,22],bus:[0,14],label:[0,0]};
const PORTS={
 breaker:{p:[[0,-16],[0,16]],series:true},isolator:{p:[[0,-16],[0,16]],series:true},
 abswitch:{p:[[0,-16],[0,16]],series:true},fuse:{p:[[0,-16],[0,16]],series:true},
 ct:{p:[[0,-16],[0,16]],series:true},ptr:{p:[[0,-26],[0,26]],series:true},
 dtr:{p:[[0,-16]],series:false},la:{p:[[0,0]],series:false},buspt:{p:[[0,0]],series:false},
 capbank:{p:[[0,0]],series:false},earth:{p:[[0,0]],series:false},
 incomer:{p:[[16,0],[0,0]],series:false,source:true},feederarrow:{p:[[30,0],[0,0]],series:false},
};

/* ---------- ELECTRICAL NETWORK ---------- */
let netDirty=true,energWires=new Set(),energComps=new Set();
const TOL=16;
function xform(c,p){
  const a=(c.rot||0)*Math.PI/180,s=c.sc||1;
  const px=p[0]*s,py=p[1]*s;
  return [c.x+px*Math.cos(a)-py*Math.sin(a),c.y+px*Math.sin(a)+py*Math.cos(a)];
}
function d2seg(p,a,b){
  const vx=b[0]-a[0],vy=b[1]-a[1],L2=vx*vx+vy*vy;
  let t=L2?((p[0]-a[0])*vx+(p[1]-a[1])*vy)/L2:0;t=Math.max(0,Math.min(1,t));
  return Math.hypot(p[0]-(a[0]+t*vx),p[1]-(a[1]+t*vy));
}
function nearPoly(p,pts,tol){for(let i=0;i<pts.length-1;i++)if(d2seg(p,pts[i],pts[i+1])<=tol)return true;return false;}
function buildNet(){
  const els=[];
  state.wires.forEach(w=>els.push({k:'w',id:w.id,pts:w.pts,term:w.pts,cond:true}));
  state.comps.forEach(c=>{
    if(c.type==='bus'){const e=[xform(c,[0,0]),xform(c,[(c.len||300),0])];
      els.push({k:'b',id:c.id,pts:e,term:e,cond:true});}
    else if(PORTS[c.type]){const pd=PORTS[c.type];
      els.push({k:'c',id:c.id,term:pd.p.map(p=>xform(c,p)),cond:pd.series?!c.open:false,
        src:!!pd.source,series:pd.series,comp:c});}
  });
  const adj=els.map(()=>[]);
  const touches=(A,B)=>{for(const t of A.term){
    if(B.pts){if(nearPoly(t,B.pts,TOL))return true;}
    else for(const u of B.term)if(Math.hypot(t[0]-u[0],t[1]-u[1])<=TOL)return true;}return false;};
  for(let i=0;i<els.length;i++)for(let j=i+1;j<els.length;j++)
    if(touches(els[i],els[j])||touches(els[j],els[i])){adj[i].push(j);adj[j].push(i);}
  const energ=new Array(els.length).fill(false),queue=[];
  els.forEach((e,i)=>{if(e.src){energ[i]=true;queue.push(i);}});
  while(queue.length){
    const i=queue.shift(),e=els[i];
    const canRelay=e.src||((e.k==='w'||e.k==='b')&&e.cond)||(e.k==='c'&&e.series&&e.cond);
    if(!canRelay)continue;
    for(const j of adj[i])if(!energ[j]){energ[j]=true;queue.push(j);}
  }
  energWires=new Set();energComps=new Set();
  els.forEach((e,i)=>{if(energ[i]){if(e.k==='w'||e.k==='b')energWires.add(e.id);else energComps.add(e.id);}});
  netDirty=false;
  P('stEnergCt').textContent=`⚡ ${energWires.size} energized conductors`;
}

/* ---------- RENDER ---------- */
function render(){
  if(netDirty)buildNet();
  wiresG.innerHTML="";
  state.wires.forEach(w=>{
    const d="M"+w.pts.map(p=>p.join(",")).join(" L"),on=energWires.has(w.id);
    const path=document.createElementNS(SVGNS,'path');
    path.setAttribute("d",d);
    path.setAttribute("class","wire"+(w.bus?" busline":"")+(animOn&&on?" flowing":"")+(w.id===selId?" sel":""));
    path.dataset.id=w.id;wiresG.appendChild(path);
    if(animOn&&on){const fp=document.createElementNS(SVGNS,'path');
      fp.setAttribute("d",d);fp.setAttribute("class","flowDots on");wiresG.appendChild(fp);}
  });
  compsG.innerHTML="";
  state.comps.forEach(c=>{
    const g=document.createElementNS(SVGNS,'g'),sc=c.sc||1,on=energComps.has(c.id);
    g.setAttribute("class","comp"+(c.id===selId?" sel":"")+(animOn&&!on&&c.type!=='label'&&c.type!=='bus'?" dead":""));
    g.setAttribute("transform",`translate(${c.x},${c.y}) rotate(${c.rot||0}) scale(${sc})`);
    g.dataset.id=c.id;
    let inner="";const lblFs=c.textSize||10.5;
    if(c.type==="bus"){
      const L=c.len||300;
      inner=`<g class="symWrap"><line x1="0" y1="0" x2="${L}" y2="0" stroke="${animOn&&on?'var(--energ)':'var(--sym)'}" stroke-width="6"/></g>`;
      if(animOn&&on)inner+=`<line x1="0" y1="0" x2="${L}" y2="0" class="flowDots on" style="display:inline"/>`;
      inner+=`<rect class="selBox" x="-6" y="-10" width="${L+12}" height="20"/>`;
      if(c.label)inner+=`<text class="lblB" style="font-size:${c.textSize||12}px" x="4" y="-9">${esc(c.label)}</text>`;
    }else if(c.type==="label"){
      const fs=c.textSize||13;
      inner=`<text class="lblB" style="font-size:${fs}px" text-anchor="middle">${esc(c.label||"TEXT")}</text>`;
      const w=(c.label||"TEXT").length*fs*0.62;
      inner+=`<rect class="selBox" x="${-w/2}" y="-${fs}" width="${w}" height="${fs*1.5}"/>`;
    }else{
      inner=`<g class="symWrap">${SYM[c.type]?SYM[c.type](c):""}</g>`;
      const [bw,bh]=BOX[c.type]||[30,30];
      if(c.open&&SWITCHABLE.has(c.type))
        inner+=`<g class="openMark"><circle cx="${bw/2+9}" cy="${-bh/2-2}" r="7.5" fill="#ff5252"/><text x="${bw/2+9}" y="${-bh/2+1.5}" text-anchor="middle" style="font:bold 9px Arial;fill:#fff">⊘</text></g>`;
      inner+=`<rect class="selBox" x="${-bw/2-3}" y="${-bh/2-3}" width="${bw+6}" height="${bh+6}"/>`;
      if(c.label)inner+=`<text class="lbl" style="font-size:${lblFs}px" text-anchor="middle" transform="rotate(${-(c.rot||0)}) translate(0,${bh/2+lblFs+3})">${esc(c.label)}</text>`;
    }
    g.innerHTML=inner;compsG.appendChild(g);
  });
  applyView();
  P('stCount').textContent=`${state.comps.length} parts · ${state.wires.length} wires`;
}
const esc=s=>(s||"").replace(/&/g,"&amp;").replace(/</g,"&lt;");
function applyView(){vp.setAttribute("transform",`translate(${view.x},${view.y}) scale(${view.k})`)}

/* ---------- COORDS ---------- */
function toWorld(ev){const r=svg.getBoundingClientRect();
