<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
<title>TGSPDCL — SLD Studio Pro V5</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<style>
:root{
  --bg:#0b0f14; --panel:#141b24; --panel2:#1e2836; --line:#2e3d52;
  --txt:#f0f4f8; --dim:#8fa0b5; --acc:#ffb300; --grn:#00e676; --red:#ff5252;
  --cyan:#00e5ff;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
body{font:12px 'Segoe UI',-apple-system,Arial,sans-serif;background:var(--bg);color:var(--txt);
  height:100vh;height:100dvh;display:flex;flex-direction:column;overflow:hidden}
button,select,input,textarea{font-family:inherit}
::-webkit-scrollbar{width:8px;height:8px}
::-webkit-scrollbar-thumb{background:var(--panel2);border-radius:4px}

/* ============ HEADER ============ */
#topbar{display:flex;align-items:center;gap:6px;padding:8px 12px;
  background:linear-gradient(180deg,#18222e,var(--panel));
  border-bottom:2px solid var(--acc);overflow-x:auto;flex-shrink:0;scrollbar-width:none}
#topbar::-webkit-scrollbar{display:none}
.logo{font-weight:900;color:var(--acc);font-size:14px;white-space:nowrap;
  letter-spacing:.5px;margin-right:6px;display:flex;align-items:center;gap:6px}
.logo .bolt{filter:drop-shadow(0 0 6px #ffb30099)}
#ssName{background:var(--panel2);border:1px solid var(--line);color:var(--txt);
  padding:7px 10px;border-radius:7px;width:215px;font-weight:600;font-size:13px}
#ssName:focus{outline:none;border-color:var(--acc)}
.sep{width:1px;height:26px;background:var(--line);margin:0 4px;flex-shrink:0}
.tb{background:var(--panel2);color:var(--txt);border:1px solid var(--line);
  border-radius:7px;padding:8px 14px;cursor:pointer;font-size:12px;font-weight:500;
  white-space:nowrap;flex-shrink:0;display:flex;align-items:center;gap:5px;transition:all .15s ease}
.tb:hover{background:var(--line);border-color:var(--dim)}
.tb:active{transform:scale(.97)}
.tb.on{background:var(--acc);color:#0b0f14;font-weight:700;border-color:var(--acc);
  box-shadow:0 0 14px #ffb30055}
.tb.lock-on{background:var(--red);color:#fff;border-color:var(--red);font-weight:700}
.tb:disabled{opacity:.25;cursor:default;pointer-events:none}
.themeSelect{background:var(--panel2);color:var(--txt);border:1px solid var(--line);
  border-radius:7px;padding:8px 10px;font-size:12px;cursor:pointer;flex-shrink:0}

/* SECONDARY RIBBON */
#toolrow{display:flex;align-items:center;gap:6px;padding:6px 12px;
  background:var(--panel2);border-bottom:1px solid var(--line);
  overflow-x:auto;flex-shrink:0;scrollbar-width:none}
#toolrow::-webkit-scrollbar{display:none}
.hintText{font-size:11px;color:var(--dim);white-space:nowrap;margin-left:auto}

/* ============ LAYOUT ============ */
#main{flex:1;display:flex;overflow:hidden;position:relative}
#palette{width:180px;background:var(--panel);border-right:1px solid var(--line);
  overflow-y:auto;flex-shrink:0;transition:margin-left .25s cubic-bezier(.4,0,.2,1)}
#palette.hidden{margin-left:-180px}
.acc{border-bottom:1px solid var(--line)}
.acc>header{display:flex;justify-content:space-between;align-items:center;
  padding:12px 14px;cursor:pointer;font-size:11px;font-weight:700;
  color:var(--acc);text-transform:uppercase;letter-spacing:.08em;user-select:none;
  background:rgba(0,0,0,.15)}
.acc>header .car{transition:transform .2s;color:var(--dim);font-size:9px}
.acc.open>header .car{transform:rotate(90deg)}
.acc>.items{display:none;padding:8px;grid-template-columns:1fr 1fr;gap:8px}
.acc.open>.items{display:grid}
.palItem{display:flex;flex-direction:column;align-items:center;gap:4px;
  background:var(--panel2);border:1px solid var(--line);border-radius:8px;
  padding:10px 4px;cursor:pointer;transition:all .12s ease}
.palItem:hover,.palItem.armed{border-color:var(--acc);background:#263547;box-shadow:0 0 10px #ffb30033}
.palItem svg{pointer-events:none}
.palItem span{font-size:10px;color:var(--dim);text-align:center;line-height:1.2}

#canvasWrap{flex:1;position:relative;overflow:hidden;background:#11171e}
#svgHost{width:100%;height:100%;cursor:default;touch-action:none}
#svgHost.wiring{cursor:crosshair}
#svgHost.placing{cursor:copy}
#fab{position:absolute;right:16px;bottom:16px;display:flex;flex-direction:column;gap:8px;z-index:5}
#fab button{width:42px;height:42px;border-radius:12px;border:1px solid var(--line);
  background:var(--panel);color:var(--txt);font-size:16px;cursor:pointer;font-weight:bold;
  box-shadow:0 4px 12px rgba(0,0,0,.5);display:flex;align-items:center;justify-content:center}
#fab button:hover{background:var(--panel2);color:var(--acc)}
#legendHint{position:absolute;left:14px;bottom:14px;background:rgba(20,27,36,.85);
  border:1px solid var(--line);border-radius:9px;padding:8px 12px;font-size:10.5px;
  color:var(--dim);backdrop-filter:blur(4px);pointer-events:none;line-height:1.6}
#legendHint b{color:var(--grn)} #legendHint i{color:var(--red);font-style:normal}

/* PROPS */
#props{width:292px;background:var(--panel);border-left:1px solid var(--line);
  overflow-y:auto;padding:14px;flex-shrink:0;display:none}
#props.open{display:block}
#props h2{font-size:14px;color:var(--acc);letter-spacing:.3px}
#props .typ{font-size:11px;color:var(--dim);margin:3px 0 12px;font-family:monospace}
#props label{display:block;font-size:11px;color:var(--dim);margin:10px 0 4px;font-weight:500}
#props input,#props textarea,#props select{width:100%;background:var(--panel2);
  border:1px solid var(--line);color:var(--txt);border-radius:6px;padding:8px;font-size:12px;transition:border .15s}
#props input:focus,#props select:focus,#props textarea:focus{border-color:var(--acc);outline:none}
#props textarea{resize:vertical;min-height:60px}
#props .row{display:flex;gap:8px}#props .row>*{flex:1}
.sizer{display:flex;align-items:center;gap:6px;margin-top:4px}
.sizer button{width:38px;height:34px;border-radius:6px;border:1px solid var(--line);
  background:var(--panel2);color:var(--txt);font-size:16px;cursor:pointer;font-weight:bold}
.sizer button:hover{background:var(--line)}
#swStateCtrlBlock{display:none;background:rgba(255,179,0,.06);padding:10px;
  border-radius:8px;border:1px solid var(--line);margin-top:10px}
#bToggleSw{width:100%;padding:12px;border-radius:8px;border:none;cursor:pointer;
  font-weight:800;font-size:13px;letter-spacing:.03em;margin-top:6px}
#bToggleSw.closed{background:var(--grn);color:#06310f}
#bToggleSw.open{background:var(--red);color:#fff}
#props .btns{display:flex;gap:6px;margin-top:16px}
#props .btns button{flex:1;padding:10px;border-radius:6px;border:none;cursor:pointer;font-weight:600;font-size:12px}
#bDel{background:var(--red);color:#fff}
#bRot90,#bDup{background:var(--panel2);color:var(--txt);border:1px solid var(--line)!important}
.statBox{background:var(--panel2);border:1px solid var(--line);border-radius:8px;padding:10px;margin-top:12px}
.statBox h4{font-size:11px;color:var(--acc);margin-bottom:6px;text-transform:uppercase;letter-spacing:.5px}
.statBox .kv{display:flex;justify-content:space-between;font-size:11.5px;padding:4px 0;border-bottom:1px dashed rgba(46,61,82,.5)}
.statBox .kv b{color:var(--grn)}
.viewOnlyTag{display:none;background:rgba(255,82,82,.12);color:var(--red);font-size:11px;
  font-weight:600;border-radius:6px;padding:7px;margin-bottom:12px;text-align:center;border:1px solid var(--red)}
body.locked .viewOnlyTag{display:block}
body.locked #props .btns{display:none}

#status{padding:6px 14px;background:var(--panel);border-top:1px solid var(--line);
  font-size:11px;color:var(--dim);display:flex;gap:18px;overflow-x:auto;flex-shrink:0;white-space:nowrap;scrollbar-width:none}
#status::-webkit-scrollbar{display:none}
#status .hot{color:var(--acc);font-weight:bold}

/* ============ SVG THEMES ============ */
#svgHost{--paper:#0e1318;--sym:#dfe9f2;--symfill:#11171e;--wire:#506f8f;
  --flow:#ccff90;--energ:#00e676;--dead:#3a4754}
#svgHost.th-light{--paper:#ffffff;--sym:#000000;--symfill:#ffffff;--wire:#0a0a0a;
  --flow:#00b0ff;--energ:#0a7a2f;--dead:#9aa7b5}
#svgHost.th-blue{--paper:#05202f;--sym:#a4d8f8;--symfill:#05202f;--wire:#4f7f9f;
  --flow:#00e5ff;--energ:#00e676;--dead:#274457}
#paper{fill:var(--paper);stroke:var(--line)}
.wire{stroke:var(--wire);stroke-width:2.2;fill:none;cursor:pointer;transition:stroke .15s}
.wire.sel{stroke:var(--acc)!important;stroke-width:3}
.wire.busline{stroke-width:6}
body.anim .wire.flowing{stroke:var(--energ)}
.flowDots{display:none;fill:none;stroke:var(--flow);stroke-width:2.8;
  stroke-dasharray:8 16;stroke-linecap:round;animation:fl 1.05s linear infinite;
  pointer-events:none;filter:drop-shadow(0 0 3px var(--flow))}
body.anim .flowDots.on{display:inline}
@keyframes fl{to{stroke-dashoffset:-24}}
.comp{cursor:move}
body.locked .comp{cursor:pointer}
.comp.sel .selBox{display:block}
.selBox{display:none;fill:none;stroke:var(--acc);stroke-width:1.5;stroke-dasharray:4 3;
  pointer-events:none;vector-effect:non-scaling-stroke}
.openMark{pointer-events:none}
text.lbl{font-family:'Courier New',monospace;font-size:11px;fill:var(--sym);user-select:none}
text.lblB{font-family:'Courier New',monospace;font-weight:bold;font-size:12px;fill:var(--sym);user-select:none}
body.anim .comp.dead .symWrap{opacity:.4}

/* ============ MODALS ============ */
.modal{position:fixed;inset:0;background:rgba(0,0,0,.85);display:none;
  align-items:center;justify-content:center;z-index:60;padding:16px;opacity:0;transition:opacity .2s}
.modal.open{display:flex;opacity:1}
.modal .box{background:var(--panel);border:1px solid var(--line);border-radius:12px;
  padding:20px;width:520px;max-width:96vw;max-height:88vh;overflow:auto;box-shadow:0 10px 30px rgba(0,0,0,.5)}
.modal h3{color:var(--acc);margin-bottom:12px;font-size:15px;font-weight:700}
.modal textarea{width:100%;height:200px;background:var(--panel2);color:var(--txt);
  border:1px solid var(--line);border-radius:6px;padding:10px;font:11px monospace}
.modal label{display:block;font-size:11px;color:var(--dim);margin:10px 0 4px;font-weight:500}
.modal select,.modal input[type=number],.modal input[type=range],.modal input[type=file]{
  width:100%;background:var(--panel2);border:1px solid var(--line);color:var(--txt);
  border-radius:6px;padding:8px;font-size:12px}
.modal .btns{display:flex;gap:8px;margin-top:14px;flex-wrap:wrap}
.modal button{padding:9px 16px;border-radius:6px;border:1px solid var(--line);
  background:var(--panel2);color:var(--txt);cursor:pointer;font-weight:500}
.modal button.pri{background:var(--acc);color:#0b0f14;font-weight:700;border:none}
.modal button:hover{background:var(--line)}
.modal .note{font-size:11px;color:var(--dim);line-height:1.55;margin-top:10px;
  background:var(--panel2);border-radius:7px;padding:10px}
.sldRow{display:flex;justify-content:space-between;align-items:center;
  background:var(--panel2);border:1px solid var(--line);border-radius:8px;padding:10px 14px;margin-bottom:8px}
.sldRow .nm{font-weight:600;font-size:13px}.sldRow .dt{font-size:11px;color:var(--dim);margin-top:2px}
.sldRow .act{display:flex;gap:6px}.sldRow .act button{padding:6px 12px;font-size:11px}
.uRow{display:flex;gap:8px;align-items:center;margin-top:8px}
.uRow label{margin:0;flex-shrink:0;width:62px}.uRow input{flex:1}
</style>
</head>
<body class="locked">

<div id="topbar">
  <span class="logo"><span class="bolt">⚡</span>SLD STUDIO PRO <span style="color:var(--dim);font-size:10px">V5</span></span>
  <input id="ssName" value="33/11KV Golconda SS">
  <div class="sep"></div>
  <button class="tb lock-on" id="bLock">🔒 Locked</button>
  <button class="tb" id="bUndo" disabled>↶</button>
  <button class="tb" id="bRedo" disabled>↷</button>
  <div class="sep"></div>
  <button class="tb on" id="bAnim">⏸ Flow Analysis</button>
  <select class="themeSelect" id="themeSel">
    <option value="">● Dark</option>
    <option value="th-blue" selected>◆ SCADA Blue</option>
    <option value="th-light">☀ Light</option>
  </select>
  <div class="sep"></div>
  <button class="tb" id="bAutoGen" style="border-color:var(--grn);color:var(--grn)">🤖 Auto Generate</button>
  <button class="tb" id="bImgLoader">📷 Trace Image/PDF</button>
  <button class="tb" id="bMySlds">🗂 Diagrams</button>
  <button class="tb" id="bSave">💾 Save</button>
  <button class="tb" id="bJson">{} JSON</button>
  <button class="tb" id="bPrint" style="border-color:var(--cyan);color:var(--cyan)">🖨️ Print / PDF</button>
  <button class="tb" id="bClear" style="color:var(--red)">✕ New</button>
</div>

<div id="toolrow">
  <button class="tb" id="bPal">📦 Switchgear Parts</button>
  <button class="tb on" id="bSelect">▢ Select</button>
  <button class="tb" id="bWire">─ Wire</button>
  <button class="tb" id="bText">A Text</button>
  <span class="hintText">💡 Wire: tap points → double-tap to finish · Double-tap any switch to OPEN/CLOSE</span>
</div>

<div id="main">
  <div id="palette" class="hidden">
    <div class="acc open"><header>Switchgear <span class="car">▶</span></header><div class="items">
      <div class="palItem" data-type="breaker"><svg width="30" height="28" viewBox="-15 -14 30 28"><rect x="-10" y="-10" width="20" height="20" fill="none" stroke="#cfe3f5" stroke-width="2"/><line x1="-7" y1="-7" x2="7" y2="7" stroke="#cfe3f5" stroke-width="1.4"/><line x1="7" y1="-7" x2="-7" y2="7" stroke="#cfe3f5" stroke-width="1.4"/></svg><span>Breaker/VCB</span></div>
      <div class="palItem" data-type="isolator"><svg width="26" height="30" viewBox="-13 -15 26 30"><line x1="0" y1="-13" x2="0" y2="-5" stroke="#cfe3f5" stroke-width="1.8"/><circle cx="0" cy="-4" r="2.6" fill="none" stroke="#cfe3f5" stroke-width="1.4"/><line x1="0" y1="-4" x2="9" y2="5" stroke="#cfe3f5" stroke-width="1.8"/><circle cx="0" cy="5" r="2.6" fill="none" stroke="#cfe3f5" stroke-width="1.4"/><line x1="0" y1="5" x2="0" y2="13" stroke="#cfe3f5" stroke-width="1.8"/></svg><span>Isolator</span></div>
      <div class="palItem" data-type="abswitch"><svg width="26" height="30" viewBox="-13 -15 26 30"><line x1="0" y1="-13" x2="0" y2="-5" stroke="#cfe3f5" stroke-width="1.8"/><line x1="0" y1="-5" x2="10" y2="5" stroke="#cfe3f5" stroke-width="2"/><line x1="6" y1="0" x2="11" y2="4" stroke="#cfe3f5" stroke-width="1.2"/><circle cx="0" cy="5" r="2.2" fill="#cfe3f5"/><line x1="0" y1="5" x2="0" y2="13" stroke="#cfe3f5" stroke-width="1.8"/></svg><span>AB Switch</span></div>
      <div class="palItem" data-type="fuse"><svg width="22" height="28" viewBox="-11 -14 22 28"><rect x="-6" y="-10" width="12" height="20" fill="none" stroke="#cfe3f5" stroke-width="1.6"/><line x1="0" y1="-14" x2="0" y2="-10" stroke="#cfe3f5" stroke-width="1.8"/><line x1="0" y1="10" x2="0" y2="14" stroke="#cfe3f5" stroke-width="1.8"/><text x="0" y="4" text-anchor="middle" font-size="8" font-weight="bold" fill="#cfe3f5">F</text></svg><span>Fuse</span></div>
    </div></div>
    <div class="acc"><header>Transformers <span class="car">▶</span></header><div class="items">
      <div class="palItem" data-type="ptr"><svg width="30" height="36" viewBox="-15 -2 30 36"><circle cx="0" cy="9" r="8.5" fill="none" stroke="#ff8a80" stroke-width="1.8"/><circle cx="0" cy="22" r="8.5" fill="none" stroke="#ff8a80" stroke-width="1.8"/></svg><span>PTR</span></div>
      <div class="palItem" data-type="dtr"><svg width="26" height="34" viewBox="-13 -2 26 34"><circle cx="0" cy="8" r="6" fill="none" stroke="#cfe3f5" stroke-width="1.5"/><circle cx="0" cy="18" r="6" fill="none" stroke="#cfe3f5" stroke-width="1.5"/><line x1="0" y1="24" x2="0" y2="28" stroke="#cfe3f5" stroke-width="1.5"/><line x1="-5" y1="28" x2="5" y2="28" stroke="#cfe3f5" stroke-width="1.8"/></svg><span>DTR/Stn Tf</span></div>
    </div></div>
    <div class="acc"><header>Protection <span class="car">▶</span></header><div class="items">
      <div class="palItem" data-type="la"><svg width="24" height="32" viewBox="-12 -2 24 32"><line x1="0" y1="0" x2="0" y2="6" stroke="#cfe3f5" stroke-width="1.6"/><polygon points="0,6 -6,17 6,17" fill="#cfe3f5"/><line x1="0" y1="17" x2="0" y2="22" stroke="#cfe3f5" stroke-width="1.6"/><line x1="-7" y1="22" x2="7" y2="22" stroke="#cfe3f5" stroke-width="2"/><line x1="-4" y1="26" x2="4" y2="26" stroke="#cfe3f5" stroke-width="1.4"/></svg><span>LA</span></div>
      <div class="palItem" data-type="buspt"><svg width="24" height="36" viewBox="-12 -2 24 36"><line x1="0" y1="0" x2="0" y2="4" stroke="#cfe3f5" stroke-width="1.6"/><circle cx="0" cy="10" r="5.5" fill="none" stroke="#80d8ff" stroke-width="1.5"/><circle cx="0" cy="20" r="5.5" fill="none" stroke="#80d8ff" stroke-width="1.5"/><line x1="0" y1="26" x2="0" y2="29" stroke="#cfe3f5" stroke-width="1.4"/><line x1="-6" y1="29" x2="6" y2="29" stroke="#cfe3f5" stroke-width="1.8"/></svg><span>Bus PT</span></div>
      <div class="palItem" data-type="ct"><svg width="22" height="28" viewBox="-11 -14 22 28"><line x1="0" y1="-13" x2="0" y2="13" stroke="#cfe3f5" stroke-width="1.8"/><circle cx="0" cy="0" r="7" fill="none" stroke="#cfe3f5" stroke-width="1.6"/></svg><span>CT</span></div>
      <div class="palItem" data-type="capbank"><svg width="28" height="32" viewBox="-14 -2 28 32"><line x1="0" y1="0" x2="0" y2="8" stroke="#cfe3f5" stroke-width="1.6"/><rect x="-10" y="8" width="20" height="4" fill="#cfe3f5"/><rect x="-10" y="15" width="20" height="4" fill="#cfe3f5"/><line x1="0" y1="19" x2="0" y2="25" stroke="#cfe3f5" stroke-width="1.6"/><line x1="-7" y1="25" x2="7" y2="25" stroke="#cfe3f5" stroke-width="1.8"/></svg><span>Cap Bank</span></div>
      <div class="palItem" data-type="earth"><svg width="22" height="24" viewBox="-11 -2 22 24"><line x1="0" y1="0" x2="0" y2="8" stroke="#cfe3f5" stroke-width="1.6"/><line x1="-8" y1="8" x2="8" y2="8" stroke="#cfe3f5" stroke-width="2"/><line x1="-5" y1="13" x2="5" y2="13" stroke="#cfe3f5" stroke-width="1.5"/><line x1="-2.5" y1="18" x2="2.5" y2="18" stroke="#cfe3f5" stroke-width="1.1"/></svg><span>Earth</span></div>
    </div></div>
    <div class="acc"><header>Network <span class="car">▶</span></header><div class="items">
      <div class="palItem" data-type="bus"><svg width="36" height="14" viewBox="0 -7 36 14"><line x1="2" y1="0" x2="34" y2="0" stroke="#cfe3f5" stroke-width="5"/></svg><span>Bus Bar</span></div>
      <div class="palItem" data-type="incomer"><svg width="36" height="18" viewBox="0 -9 36 18"><line x1="2" y1="0" x2="22" y2="0" stroke="#cfe3f5" stroke-width="1.8"/><polygon points="34,0 21,-6 21,6" fill="#42a5f5"/></svg><span>Incomer</span></div>
      <div class="palItem" data-type="feederarrow"><svg width="36" height="18" viewBox="0 -9 36 18"><line x1="14" y1="0" x2="34" y2="0" stroke="#cfe3f5" stroke-width="1.8"/><polygon points="2,0 15,-6 15,6" fill="#cfe3f5"/></svg><span>Feeder Arrow</span></div>
      <div class="palItem" data-type="label"><svg width="36" height="18" viewBox="0 0 36 18"><text x="18" y="14" text-anchor="middle" font-size="13" font-weight="bold" fill="#cfe3f5">Aa</text></svg><span>Text</span></div>
    </div></div>
  </div>

  <div id="canvasWrap">
    <svg id="svgHost" class="th-blue" xmlns="http://www.w3.org/2000/svg">
      <g id="viewport">
        <rect id="paper" x="0" y="0" width="1600" height="980" stroke-width="2"/>
        <image id="underlayImg" x="0" y="0" style="display:none" opacity="0.45" preserveAspectRatio="xMidYMid meet"/>
        <g id="wiresG"></g><g id="compsG"></g><g id="wireDraftG"></g>
      </g>
    </svg>
    <div id="fab"><button id="bZin">＋</button><button id="bZout">－</button><button id="bZfit">⛶</button></div>
    <div id="legendHint">⚡ Flow ON: <b>green = energized</b> · <i>red ⊘ = OPEN (blocks flow)</i><br>Double-tap any breaker / isolator / AB switch / fuse to operate it</div>
