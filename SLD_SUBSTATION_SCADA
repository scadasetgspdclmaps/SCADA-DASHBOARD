/* ============================================================
   🤖 AUTO-GENERATE MODULE  (V5 addition — isolated)
   Reuses the EXACT existing import path: assign to state, then
   closeProps → netDirty → render → fit → reset history → pushHist
   (same sequence as jApply). Touches nothing in buildNet/render/PORTS.
   ============================================================ */
function applyGeneratedSld(json){
  if(!json||!Array.isArray(json.comps)||!Array.isArray(json.wires)){
    toast("Generator returned no usable diagram");return;}
  /* normalize: guarantee every comp has the V4 fields buildNet/render expect */
  let maxId=0;
  json.comps.forEach(c=>{
    c.id=c.id||nid("c");c.rot=c.rot||0;c.sc=c.sc||1;c.label=c.label||"";
    c.textSize=c.textSize||(c.type==='label'?13:10);c.bio=c.bio||{};
    const m=/(\d+)$/.exec(c.id);if(m)maxId=Math.max(maxId,+m[1]);
  });
  json.wires.forEach(w=>{w.id=w.id||nid("w")});
  uid=Math.max(uid,maxId+1);                 /* avoid id collisions */
  state={underlay:state.underlay,name:json.name||"Generated SS",
         comps:json.comps,wires:json.wires};
  P('ssName').value=state.name;
  selId=null;closeProps();netDirty=true;render();fit();
  hist=[];hPtr=-1;pushHist();
  P('autoGenModal').classList.remove('open');
  toast("SLD generated ✓ — unlock ✏️ to rename/move/edit");
}

/* ---- client-side offline template builder (Phase-1 fallback) ---- */
function buildTemplateClient(opts){
  let q=1;const id=p=>"a"+p+(q++);
  const comps=[],wires=[];
  const C=(type,x,y,rot,label,extra)=>{const c=Object.assign(
    {id:id("c"),type,x,y,rot:rot||0,sc:1,label:label||"",
     textSize:type==='label'?13:10,bio:{}},extra||{});comps.push(c);return c;};
  const W=pts=>wires.push({id:id("w"),pts});
  const RIGHT=1480,HVY=300,LVY=640,PTRY=500;
  const spread=(n,lo,hi)=>n<=0?[]:n===1?[(lo+hi)/2]:
    Array.from({length:n},(_,i)=>Math.round(lo+i*(hi-lo)/(n-1)));

  C("label",800,36,0,"SINGLE LINE DIAGRAM OF "+opts.name.toUpperCase(),{textSize:22});
  C("label",800,58,0,"TGSPDCL — SCADA CIRCLE",{textSize:11});
  C("bus",120,HVY,0,"33 KV BUS",{len:RIGHT-120+20,textSize:13});

  spread(opts.incN,200,RIGHT-160).forEach((x,i)=>{
    C("label",x,90,0,"33KV INCOMER-"+(i+1),{textSize:11});
    C("incomer",x,124,90,"");W([[x,140],[x,162]]);
    C("la",x+34,150,0,"33KV LAs");W([[x,150],[x+34,150]]);
    C("isolator",x,180,0,"");W([[x,196],[x,216]]);
    C("breaker",x,228,0,"");W([[x,244],[x,258]]);
    C("isolator",x,274,0,"");W([[x,290],[x,HVY]]);
  });
  C("buspt",146,HVY,0,"33KV BUS PT");

  const roman=["I","II","III","IV","V","VI","VII","VIII"];
  spread(opts.ptrN,320,RIGHT-200).forEach((x,i)=>{
    W([[x,HVY],[x,332]]);
    C("isolator",x,348,0,"");W([[x,364],[x,378]]);
    C("breaker",x,394,0,"HV");W([[x,410],[x,424]]);
    C("fuse",x,440,0,"");W([[x,456],[x,474]]);
    const p=C("ptr",x,PTRY,0,opts.ptrR+" - PTR-"+roman[i]);
    p.bio={rating:opts.ptrR,remarks:"33/11kV Power Transformer"};
    W([[x,526],[x,544]]);C("fuse",x,560,0,"");W([[x,576],[x,590]]);
    C("breaker",x,606,0,"LV");W([[x,622],[x,LVY]]);
  });

  C("bus",120,LVY,0,"11 KV BUS",{len:RIGHT-120+20,textSize:13});
  C("buspt",480,LVY,0,"11KV BUS PT");

  spread(opts.fdrN,180,RIGHT-30).forEach((x,i)=>{
    W([[x,LVY],[x,670]]);
    C("isolator",x,686,0,"");W([[x,702],[x,716]]);
    const name=opts.fdrNames[i]||("11KV FEEDER-"+(i+1));
    const b=C("breaker",x,732,0,"");b.bio={rating:"630A VCB",remarks:name};
    W([[x,748],[x,764]]);C("isolator",x,780,0,"");W([[x,796],[x,818]]);
    C("feederarrow",x,818,90,"");C("label",x,910,90,name,{textSize:10});
  });
  return {name:opts.name,comps,wires};
}

P('bAutoGen').onclick=()=>P('autoGenModal').classList.add('open');
P('agClose').onclick=()=>P('autoGenModal').classList.remove('open');

P('agTemplate').onclick=()=>{
  const names=P('agFdrList').value.split("\n").map(s=>s.trim()).filter(Boolean);
  applyGeneratedSld(buildTemplateClient({
    name:P('agName').value||"33/11KV New Substation",
    ptrN:Math.max(1,+P('agPtrN').value||2),
    ptrR:P('agPtrR').value||"12.5 MVA",
    incN:Math.max(1,+P('agIncN').value||2),
    fdrN:Math.max(names.length,+P('agFdrN').value||8),
    fdrNames:names,
  }));
};

P('agRun').onclick=async()=>{
  const f=P('agFile').files[0];
  if(!f){toast("Choose a PDF or image first");return;}
  const url=(P('agUrl').value||"").replace(/\/+$/,"")+"/generate-sld";
  toast("Uploading to AI server… (OCR may take ~10–30s)");
  try{
    const fd=new FormData();fd.append("file",f);
    const res=await fetch(url,{method:"POST",body:fd});
    if(!res.ok)throw new Error("HTTP "+res.status);
    const json=await res.json();
    applyGeneratedSld(json);
    if(json._note)toast(json._note);
  }catch(e){
    toast("Backend unreachable — use Build Offline Template instead");
  }
};



