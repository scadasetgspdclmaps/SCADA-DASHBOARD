P('uFile').addEventListener('change',async ev=>{
  const f=ev.target.files[0];if(!f)return;
  try{let dataUrl;
    if(f.type==="application/pdf"||f.name.toLowerCase().endsWith(".pdf")){
      toast("Rendering PDF page 1…");
      const buf=await f.arrayBuffer();
      pdfjsLib.GlobalWorkerOptions.workerSrc="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js";
      const pdf=await pdfjsLib.getDocument({data:buf}).promise,page=await pdf.getPage(1);
      const vpt=page.getViewport({scale:2}),cv=document.createElement('canvas');
      cv.width=vpt.width;cv.height=vpt.height;
      await page.render({canvasContext:cv.getContext('2d'),viewport:vpt}).promise;
      dataUrl=cv.toDataURL("image/png");
    }else dataUrl=await new Promise((res,rej)=>{const r=new FileReader();r.onload=()=>res(r.result);r.onerror=rej;r.readAsDataURL(f);});
    state.underlay={src:dataUrl,opacity:.45,w:1600,x:0,y:0,show:true};applyUnderlay();
    toast("Underlay loaded — unlock ✏️ and trace over it");
  }catch(e){alert("Could not load file: "+e.message);}
});
